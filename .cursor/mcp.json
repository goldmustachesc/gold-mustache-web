{
  "mcpServers": {
    "vercel": {
      "url": "https://mcp.vercel.com"
    },
    "prisma": {
      "command": "npx",
      "args": ["-y", "prisma-mcp-server"]
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    },
    "memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"]
    }
  }
}
